				},
				{
					"name": "CorregirUnidadCondicion"
				},
				{
					"name": "filter2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          almacen_id as integer,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          direccion as string,",
				"          capacidad_m3 as float,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          despacho_id as integer,",
				"          recepcion_id as integer,",
				"          nro_lote as string,",
				"          almacen_id as integer,",
				"          transportista_id as integer,",
				"          vehiculo_id as integer,",
				"          fecha_despacho as string,",
				"          cantidad_despachada as integer,",
				"          centro_destino as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_despacho as string,",
				"          fecha_llegada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          recepcion_id as integer,",
				"          nro_lote as string,",
				"          almacen_id as integer,",
				"          transportista_id as integer,",
				"          vehiculo_id as integer,",
				"          fecha_recepcion as string,",
				"          cantidad_recibida as integer,",
				"          unidad as string,",
				"          condicion as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_remision as string,",
				"          temperatura_llegada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source(output(",
				"          transportista_id as integer,",
				"          razon_social as string,",
				"          nit as string,",
				"          municipio as string,",
				"          contacto as string,",
				"          telefono as integer,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source4",
				"source(output(",
				"          vehiculo_id as integer,",
				"          transportista_id as integer,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as float,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source5",
				"source1 derive(departamento = case(upper(departamento) == 'LA PAZ', 'LP', upper(departamento) == 'COCHABAMBA', 'CB', upper(departamento) == 'SANTA CRUZ', 'SC', upper(departamento) == 'ORURO', 'OR', upper(departamento) == 'POTOSI' || upper(departamento) == 'POTOSÍ', 'PT', upper(departamento) == 'TARIJA', 'TJ', upper(departamento) == 'CHUQUISACA', 'CH', upper(departamento) == 'BENI', 'BN', upper(departamento) == 'PANDO', 'PD', upper(departamento))) ~> NormalizarDepartamentos",
				"source2 derive(estado = case(initCap(lower(estado)) == 'Deespachado', 'Despachado', lower(estado) == 'e ntránsito', 'En Tránsito', initCap(lower(estado)))) ~> CorregirEstado",
				"CorregirEstado derive(responsable = initCap(lower(responsable))) ~> Capitalizar",
				"CorregirDept filter(!isNull(centro_destino) && !isNull(estado) && !isNull(responsable)",
				"&& !isNull(fecha_despacho) && !isNull(fecha_llegada)) ~> filter1",
				"NormalizarDepartamentos derive(estado = initCap(lower(estado))) ~> Capitalizar2",
				"Capitalizar derive(fecha_despacho = toString(coalesce(     toDate(trim(fecha_despacho), 'yyyy-MM-dd'),     toDate(trim(fecha_despacho), 'yyyy/MM/dd'),     toDate(trim(fecha_despacho), 'dd/MM/yyyy'),     toDate(trim(fecha_despacho), 'MM/dd/yyyy'),     toDate(trim(fecha_despacho), 'dd-MM-yyyy') ), 'yyyy-MM-dd'),",
				"          fecha_llegada = toString(coalesce(     toDate(trim(fecha_llegada), 'yyyy-MM-dd'),     toDate(trim(fecha_llegada), 'yyyy/MM/dd'),     toDate(trim(fecha_llegada), 'dd/MM/yyyy'),     toDate(trim(fecha_llegada), 'MM/dd/yyyy'),     toDate(trim(fecha_llegada), 'dd-MM-yyyy') ), 'yyyy-MM-dd')) ~> NormalizarFechas",
				"NormalizarFechas derive(centro_destino = replace(replace(replace(centro_destino, 'Orruo', 'Oruro'), 'lE Alto', 'El Alto'), 'Coochabamba', 'Cochabamba')) ~> CorregirDept",
				"source3 derive(fecha_recepcion = toString(coalesce(     toDate(trim(fecha_recepcion), 'yyyy-MM-dd'),     toDate(trim(fecha_recepcion), 'yyyy/MM/dd'),     toDate(trim(fecha_recepcion), 'dd/MM/yyyy'),     toDate(trim(fecha_recepcion), 'MM/dd/yyyy'),     toDate(trim(fecha_recepcion), 'dd-MM-yyyy') ), 'yyyy-MM-dd')) ~> NormalizarFechas2",
				"NormalizarFechas2 derive(responsable = initCap(lower(responsable)),",
				"          estado = initCap(lower(estado))) ~> Capitalizar3",
				"Capitalizar3 derive(unidad = case(lower(unidad) == 'cajas', 'caja', lower(unidad) == 'unidades', 'unidad', lower(unidad) == 'kilos', 'kg', lower(unidad) == 'litros', 'lt', lower(unidad)),",
				"          condicion = case(initCap(lower({condicion})) == 'Beno', 'Bueno', initCap(lower({condicion})))) ~> CorregirUnidadCondicion",
				"CorregirUnidadCondicion filter(!isNull(unidad) && !isNull(condicion) && !isNull(nro_guia_remision) && !isNull(responsable) && !isNull(estado)",
				"&& !isNull(fecha_recepcion)) ~> filter2",
				"Capitalizar2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          almacen_id as integer,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          direccion as string,",
				"          capacidad_m3 as integer,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 1,",
				"     errorHandlingOption: 'allErrors',",
				"     transactionCommit: 'single',",
				"     reportSuccessOnError: false) ~> sink1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          despacho_id as integer,",
				"          recepcion_id as integer,",
				"          nro_lote as string,",
				"          almacen_id as integer,",
				"          transportista_id as integer,",
				"          vehiculo_id as integer,",
				"          fecha_despacho as date,",
				"          cantidad_despachada as integer,",
				"          centro_destino as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_despacho as string,",
				"          fecha_llegada as date",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 4,",
				"     errorHandlingOption: 'allErrors',",
				"     transactionCommit: 'single',",
				"     reportSuccessOnError: true) ~> sink2",
				"filter2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          recepcion_id as integer,",
				"          nro_lote as string,",
				"          almacen_id as integer,",
				"          transportista_id as integer,",
				"          vehiculo_id as integer,",
				"          fecha_recepcion as date,",
				"          cantidad_recibida as integer,",
				"          unidad as string,",
				"          condicion as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_remision as string,",
				"          temperatura_llegada as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 3,",
				"     errorHandlingOption: 'allErrors',",
				"     transactionCommit: 'single',",
				"     reportSuccessOnError: false) ~> sink3",
				"source4 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          transportista_id as integer,",
				"          razon_social as string,",
				"          nit as string,",
				"          municipio as string,",
				"          contacto as string,",
				"          telefono as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 1,",
				"     errorHandlingOption: 'allErrors',",
				"     transactionCommit: 'single',",
				"     reportSuccessOnError: false) ~> sink4",
				"source5 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          vehiculo_id as integer,",
				"          transportista_id as integer,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as integer,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 2,",
				"     errorHandlingOption: 'allErrors',",
				"     transactionCommit: 'single',",
				"     reportSuccessOnError: false) ~> sink5"
			]
		}
	}
}