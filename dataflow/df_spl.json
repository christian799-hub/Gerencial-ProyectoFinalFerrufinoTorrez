				"     saveOrder: 1,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink5",
				"filter3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_ag_id as integer,",
				"          asignacion_id as integer,",
				"          ci_beneficiaria as string,",
				"          fecha_entrega as date,",
				"          productos as string,",
				"          lote as string,",
				"          peso_kg as decimal(8,2),",
				"          punto_entrega as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 4,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink6",
				"filter4 sink(allowSchemaDrift: true,",
