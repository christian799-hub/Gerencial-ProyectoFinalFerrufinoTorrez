{
	"name": "df_gold_canal_pago",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bja_pagos_silver1",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_canal_pago",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          nombre_canal as string,",
				"          tipo_canal as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT DISTINCT\\n    canal_pago AS nombre_canal,\\n    CASE \\n        WHEN canal_pago LIKE \\'%Banco%\\' OR canal_pago LIKE \\'%Ventanilla%\\' THEN \\'Ventanilla\\'\\n        ELSE \\'Digital\\'\\n    END AS tipo_canal\\nFROM bja_pagos_silver\\nWHERE canal_pago IS NOT NULL',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          canal_pago_key as integer,",
				"          nombre_canal as string,",
				"          tipo_canal as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          nombre_canal,",
				"          tipo_canal",
				"     )) ~> sink1"
			]
		}
	}
}